---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CategoryMoreLink from '../components/CategoryMoreLink.astro';
import HomeSearch from '../components/HomeSearch.astro';
import {
  ARTICLE_LIST_LIMIT,
  AUTHOR_LIST_PATH,
  GENRE_LIST_PATH,
  SITE_DESCRIPTION,
  SITE_NAME,
} from '../lib/constants';
import {
  getAuthorArticles,
  getGenreArticles,
  sortArticlesByUpdated,
} from '../lib/articles';
import { buildWebSiteJsonLd } from '../lib/structured-data';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const authorArticles = getAuthorArticles(articles);
const genreArticles = getGenreArticles(articles);
const allArticles = [...articles].sort(sortArticlesByUpdated);
const jsonLd = [buildWebSiteJsonLd(Astro.site, SITE_DESCRIPTION)];
---

<Layout
  title={`${SITE_NAME} — 本のおすすめランキング`}
  description={SITE_DESCRIPTION}
  wide
  home
  titleSuffix={false}
  jsonLd={jsonLd}
>
  <HomeSearch slot="below-header" />
  {
    articles.length === 0 ? (
      <p class="home-empty">まだ記事がありません。npm run generate で記事を生成してください。</p>
    ) : (
      <div class="home" data-home-default>
        {
          authorArticles.length > 0 && (
            <section
              class="home-section"
              aria-labelledby="author-articles-heading"
            >
              <h2 id="author-articles-heading" class="home-section__heading">
                作家別のおすすめ
              </h2>
              <ul class="article-list" data-random-list data-random-limit={ARTICLE_LIST_LIMIT}>
                {authorArticles.map((article) => (
                  <ArticleCard article={article} />
                ))}
              </ul>
              {
                authorArticles.length > ARTICLE_LIST_LIMIT && (
                  <CategoryMoreLink href={AUTHOR_LIST_PATH} />
                )
              }
            </section>
          )
        }
        {
          genreArticles.length > 0 && (
            <section
              class="home-section"
              aria-labelledby="genre-articles-heading"
            >
              <h2 id="genre-articles-heading" class="home-section__heading">
                ジャンル別のおすすめ
              </h2>
              <ul class="article-list" data-random-list data-random-limit={ARTICLE_LIST_LIMIT}>
                {genreArticles.map((article) => (
                  <ArticleCard article={article} />
                ))}
              </ul>
              {
                genreArticles.length > ARTICLE_LIST_LIMIT && (
                  <CategoryMoreLink href={GENRE_LIST_PATH} />
                )
              }
            </section>
          )
        }
      </div>
      <section class="home-search-results" hidden data-search-results aria-live="polite">
        <ul class="article-list">
          {allArticles.map((article) => (
            <ArticleCard article={article} searchable />
          ))}
        </ul>
      </section>
    )
  }
</Layout>

<style>
  .home {
    padding: 0;
  }

  .home-search-results {
    padding: 0;
  }

  .home-empty {
    color: var(--color-muted);
    text-align: center;
    padding: 4rem 0;
    margin: 0;
  }

  .home-section + .home-section {
    margin-top: 5rem;
    padding-top: 5rem;
    border-top: 1px solid var(--color-border);
  }

  .home-section__heading {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    line-height: 1.3;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .article-list {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }
</style>
