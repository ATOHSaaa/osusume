---
import CategoryMoreLink from './CategoryMoreLink.astro';
import {
  ARTICLE_LIST_LIMIT,
  AUTHOR_LIST_PATH,
  GENRE_LIST_PATH,
} from '../lib/constants';
import { sortArticlesByAuthor } from '../lib/articles';
import type { CollectionEntry } from 'astro:content';

interface Props {
  authorArticles: CollectionEntry<'articles'>[];
  genreArticles: CollectionEntry<'articles'>[];
  currentSlug?: string;
}

const { authorArticles, genreArticles, currentSlug } = Astro.props;

const sortedAuthorArticles = [...authorArticles].sort(sortArticlesByAuthor);
const sortedGenreArticles = [...genreArticles].sort(sortArticlesByAuthor);
---

<aside class="article-nav-sidebar">
  <nav aria-label="記事一覧">
    {
      sortedAuthorArticles.length > 0 && (
        <div class="article-nav-sidebar__group">
          <h2 class="article-nav-sidebar__heading">作家別のおすすめ</h2>
          <ul
            class="article-nav-sidebar__list"
            data-random-list
            data-random-limit={ARTICLE_LIST_LIMIT}
          >
            {sortedAuthorArticles.map((article) => (
              <li>
                <a
                  href={`/articles/${article.slug}/`}
                  class="article-nav-sidebar__link"
                  aria-current={article.slug === currentSlug ? 'page' : undefined}
                >
                  {article.data.author}
                </a>
              </li>
            ))}
          </ul>
          {
            sortedAuthorArticles.length > ARTICLE_LIST_LIMIT && (
              <CategoryMoreLink href={AUTHOR_LIST_PATH} class="sidebar-more" />
            )
          }
        </div>
      )
    }
    {
      sortedGenreArticles.length > 0 && (
        <div class="article-nav-sidebar__group">
          <h2 class="article-nav-sidebar__heading">ジャンル別のおすすめ</h2>
          <ul
            class="article-nav-sidebar__list"
            data-random-list
            data-random-limit={ARTICLE_LIST_LIMIT}
          >
            {sortedGenreArticles.map((article) => (
              <li>
                <a
                  href={`/articles/${article.slug}/`}
                  class="article-nav-sidebar__link"
                  aria-current={article.slug === currentSlug ? 'page' : undefined}
                >
                  {article.data.author}
                </a>
              </li>
            ))}
          </ul>
          {
            sortedGenreArticles.length > ARTICLE_LIST_LIMIT && (
              <CategoryMoreLink href={GENRE_LIST_PATH} class="sidebar-more" />
            )
          }
        </div>
      )
    }
  </nav>
</aside>

<style is:global>
  .article-nav-sidebar__group + .article-nav-sidebar__group {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .article-nav-sidebar__heading {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: var(--heading-letter-spacing);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .article-nav-sidebar__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .article-nav-sidebar__link {
    display: block;
    padding: 0.375rem 0.625rem;
    margin: 0 -0.625rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-text);
    text-decoration: none;
  }

  .article-nav-sidebar__group .sidebar-more {
    margin-top: 0.75rem;
    padding: 0.5rem 0.625rem;
    font-size: 0.8125rem;
  }
</style>
