---
import BookCard from '../components/BookCard.astro';
import Sources from '../components/Sources.astro';
import { MAX_BOOKS } from '../lib/constants';

interface Props {
  kind?: 'author' | 'genre';
  books: Array<{
    title: string;
    count: number;
    amazonUrl?: string;
    imageUrl?: string;
    price?: string;
    author?: string;
  }>;
  sources: Array<{
    title: string;
    url: string;
    siteName?: string;
  }>;
}

const { books, sources, kind = 'author' } = Astro.props;
const showBookAuthor = kind === 'genre';
const rankedBooks = books.slice(0, MAX_BOOKS);
---

<div class="article-books">
  <h2>おすすめ作品ランキング</h2>
  <div class="article-books__grid">
    {
      rankedBooks.map((book, i) => (
        <BookCard
          rank={i + 1}
          title={book.title}
          count={book.count}
          amazonUrl={book.amazonUrl}
          imageUrl={book.imageUrl}
          price={book.price}
          author={book.author}
          showAuthor={showBookAuthor}
        />
      ))
    }
  </div>
</div>

<Sources sources={sources} />

<style>
  .article-books {
    margin-top: 3rem;
  }

  .article-books h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-books__grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
