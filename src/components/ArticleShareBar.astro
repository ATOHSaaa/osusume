---
interface Props {
  url: string;
  title: string;
  position?: 'top' | 'bottom';
}

const { url, title, position = 'top' } = Astro.props;

const twitterUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const hatenaUrl = `https://b.hatena.ne.jp/entry/panel/?url=${encodeURIComponent(url)}&btitle=${encodeURIComponent(title)}`;
---

<div class:list={['article-share', position === 'bottom' && 'article-share--bottom']} role="group" aria-label="記事をシェア">
  <a
    class="article-share__button article-share__button--twitter"
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="X（Twitter）でシェア"
    title="X（Twitter）でシェア"
  >
    <svg class="article-share__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
      ></path>
    </svg>
  </a>
  <a
    class="article-share__button article-share__button--hatena"
    href={hatenaUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="はてなブックマークに追加"
    title="はてなブックマークに追加"
  >
    <svg class="article-share__icon article-share__icon--hatena" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="#00A4DE"
        d="M20.47 0C22.42 0 24 1.58 24 3.53v16.94c0 1.95-1.58 3.53-3.53 3.53H3.53C1.58 24 0 22.42 0 20.47V3.53C0 1.58 1.58 0 3.53 0h16.94zm-3.705 14.47c-.78 0-1.41.63-1.41 1.41s.63 1.414 1.41 1.414 1.41-.645 1.41-1.425-.63-1.41-1.41-1.41zM8.61 17.247c1.2 0 2.056-.042 2.58-.12.526-.084.976-.222 1.32-.412.45-.232.78-.564 1.02-.99s.36-.915.36-1.48c0-.78-.21-1.403-.63-1.87-.42-.48-.99-.734-1.74-.794.66-.18 1.156-.45 1.456-.81.315-.344.465-.824.465-1.424 0-.48-.103-.885-.3-1.26-.21-.36-.493-.645-.883-.87-.345-.195-.735-.315-1.215-.405-.464-.074-1.29-.12-2.474-.12H5.654v10.486H8.61zm.736-4.185c.705 0 1.185.088 1.44.262.27.18.39.495.39.93 0 .405-.135.69-.42.855-.27.18-.765.254-1.44.254H8.31v-2.297h1.05zm8.656.706v-7.06h-2.46v7.06H18zM8.925 9.08c.71 0 1.185.08 1.432.24.245.16.367.435.367.83 0 .38-.13.646-.39.804-.265.154-.747.232-1.452.232h-.57V9.08h.615z"
      ></path>
    </svg>
  </a>
  <button
    type="button"
    class="article-share__button article-share__button--copy"
    data-copy-url={url}
    aria-label="リンクをコピー"
    title="リンクをコピー"
  >
    <svg class="article-share__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
      ></path>
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
      ></path>
    </svg>
  </button>
</div>

<style>
  .article-share {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .article-share--bottom {
    margin-top: 2.5rem;
    margin-bottom: 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .article-share__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: var(--color-surface);
    color: var(--color-text);
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  .article-share__icon {
    display: block;
    flex-shrink: 0;
  }

  .article-share__button:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .article-share__button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .article-share__button--twitter:hover {
    background: rgba(15, 20, 25, 0.04);
  }

  .article-share__button--hatena:hover {
    background: rgba(0, 164, 222, 0.06);
    border-color: #00A4DE;
  }

  .article-share__button--copy:disabled {
    opacity: 0.85;
    cursor: default;
  }
</style>
