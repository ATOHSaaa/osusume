---
import Analytics from '../components/Analytics.astro';
import JsonLd from '../components/JsonLd.astro';
import {
  ABOUT_PATH,
  AUTHOR_LIST_PATH,
  CONTACT_PATH,
  GENRE_LIST_PATH,
  NOTO_SANS_JP_FONT_URL,
  PRIVACY_PATH,
  RSS_PATH,
  SITE_DESCRIPTION,
  SITE_NAME,
} from '../lib/constants';
import { absoluteUrl } from '../lib/site-url';
import {
  DEFAULT_OG_IMAGE_PATH,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_WIDTH,
} from '../lib/og-image';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  home?: boolean;
  titleSuffix?: boolean;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  wide = false,
  home = false,
  titleSuffix = true,
  ogType = 'website',
  ogImage: ogImageProp,
  ogImageAlt,
  jsonLd = [],
} = Astro.props;

const pageTitle = titleSuffix ? `${title} | ${SITE_NAME}` : title;
const canonicalUrl = absoluteUrl(Astro.url.pathname, Astro.site);
const ogUrl = canonicalUrl;
const resolvedOgImage = ogImageProp
  ? ogImageProp.startsWith('http')
    ? ogImageProp
    : absoluteUrl(ogImageProp, Astro.site)
  : absoluteUrl(DEFAULT_OG_IMAGE_PATH, Astro.site);
const resolvedOgImageAlt = ogImageAlt ?? pageTitle;

const navItems = [
  {
    href: AUTHOR_LIST_PATH,
    label: '作家別',
    match: (path: string) => path.startsWith(AUTHOR_LIST_PATH),
  },
  {
    href: GENRE_LIST_PATH,
    label: 'ジャンル別',
    match: (path: string) => path.startsWith(GENRE_LIST_PATH),
  },
];

const footerLinks = [
  { href: '/', label: 'ホーム' },
  { href: AUTHOR_LIST_PATH, label: '作家別のおすすめ' },
  { href: GENRE_LIST_PATH, label: 'ジャンル別のおすすめ' },
  { href: RSS_PATH, label: 'RSS' },
  { href: ABOUT_PATH, label: 'このサイトについて' },
  { href: PRIVACY_PATH, label: 'プライバシーポリシー' },
  { href: CONTACT_PATH, label: 'お問い合わせ' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href={RSS_PATH} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={NOTO_SANS_JP_FONT_URL} />
    <link
      href={NOTO_SANS_JP_FONT_URL}
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href={NOTO_SANS_JP_FONT_URL} rel="stylesheet" />
    </noscript>
    <title>{pageTitle}</title>
    <Analytics />
    {jsonLd.length > 0 && <JsonLd schemas={jsonLd} />}
  </head>
  <body data-layout={wide ? 'wide' : 'default'} data-page={home ? 'home' : undefined}>
    <header class="site-header">
      <div class="site-inner site-header__inner">
        <a href="/" class="site-logo">{SITE_NAME}</a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <ul class="site-nav__list">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="site-nav__link"
                    aria-current={item.match(currentPath) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>
    <div class="below-header">
      <slot name="below-header" />
    </div>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="site-inner">
        <nav class="site-footer__nav" aria-label="フッターナビゲーション">
          <ul class="site-footer__list">
            {
              footerLinks.map((item) => (
                <li>
                  <a href={item.href} class="site-footer__link">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <p class="copyright">&copy; {new Date().getFullYear()} {SITE_NAME}</p>
      </div>
    </footer>
    <script>
      import { bindRandomArticleLists } from '../scripts/init-random-article-lists';

      bindRandomArticleLists();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #faf9f7;
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-muted: #6b7280;
    --color-accent: #c2410c;
    --color-border: #e5e7eb;
    --font-sans: 'Noto Sans JP', system-ui, sans-serif;
    --font-site-title: Futura, 'Century Gothic', 'Trebuchet MS', sans-serif;
    --site-width: 1080px;
    --layout-width: 720px;
    --layout-padding-x: 1.25rem;
    --main-padding-top: 3rem;
    --main-padding-bottom: 4rem;
    --heading-letter-spacing: 0.04em;
    --site-header-height: 4.25rem;
  }

  body[data-layout='wide'] {
    --layout-width: 1080px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    padding: var(--main-padding-top) 0 var(--main-padding-bottom);
  }

  body[data-page='home'] main {
    padding-top: 2.5rem;
  }

  .below-header:empty {
    display: none;
  }

  .container,
  .site-inner {
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--layout-padding-x);
  }

  .site-inner {
    max-width: var(--site-width);
  }

  .container {
    max-width: var(--layout-width);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-logo {
    font-family: var(--font-site-title);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: none;
    flex-shrink: 0;
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    justify-content: flex-end;
  }

  .site-nav__link {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-nav__link:hover {
    text-decoration: underline;
    text-decoration-color: #000;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .site-nav__link[aria-current='page'] {
    color: var(--color-accent);
  }

  .site-nav__link[aria-current='page']:hover {
    text-decoration-color: #000;
  }

  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .site-footer__nav {
    display: flex;
    justify-content: flex-end;
  }

  .site-footer__list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem 1.25rem;
  }

  .site-footer__link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
  }

  .site-footer__link:hover {
    color: var(--color-accent);
  }

  .copyright {
    margin: 0;
    text-align: right;
  }

  h1,
  h2,
  h3 {
    line-height: 1.3;
    letter-spacing: var(--heading-letter-spacing);
  }

  /* JS 無効時は先頭12件のみ表示（data-random-limit で上書き可） */
  [data-random-list]:not([data-random-ready]) > :nth-child(n + 13) {
    display: none;
  }

  [data-random-list][data-random-ready] > li.is-overflow {
    display: none;
  }

  a {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    :root {
      --site-header-height: 6.75rem;
    }

    .site-header__inner {
      flex-direction: column;
      align-items: stretch;
    }

    .site-logo {
      font-size: 1.5rem;
      text-align: center;
    }

    .site-nav__list {
      justify-content: center;
    }
  }
</style>
